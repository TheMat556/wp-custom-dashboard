{
  "name": "wp-custom-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "contracts:generate": "node scripts/generate-contracts.mjs",
    "contracts:verify": "node scripts/verify-generated-contracts.mjs",
    "package:plugin": "npm run build && php scripts/package-plugin.php",
    "preview": "vite preview",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:contracts:php": "./vendor/bin/phpunit tests/php/BootPayloadContractTest.php tests/php/RestRouteContractTest.php tests/php/RestRoutePermissionCompatibilityTest.php tests/php/PluginEntryCompatibilityTest.php tests/php/ArtifactContractTest.php",
    "verify:artifact": "php scripts/verify-plugin-artifact.php",
    "verify": "bun run lint && bun run test && bun run build && composer run lint",
    "php:lint": "composer run lint"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "antd": "^6.3.7",
    "dompurify": "^3.4.1",
    "geist": "^1.7.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.10",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "dompurify": "3.4.1",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.10"
  }
}

{
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcsstandards/phpcsutils": "^1.0",
    "phpcsstandards/phpcsextra": "^1.0",
    "phpunit/phpunit": "^10",
    "yoast/phpunit-polyfills": "^2"
  },
  "scripts": {
    "lint": "phpcs --standard=WordPress --extensions=php --ignore=vendor/,node_modules/ --warning-severity=0 wp-custom-dashboard.php includes/",
    "lint-fix": "phpcbf --standard=WordPress --extensions=php --ignore=vendor/,node_modules/ wp-custom-dashboard.php includes/",
    "test": "phpunit"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}

{
  "autoload": {
    "psr-4": {
      "WpReactUi\\": "app/",
      "WpReactUi\\Contracts\\": "contracts/php/"
    }
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcsstandards/phpcsutils": "^1.0",
    "phpcsstandards/phpcsextra": "^1.0",
    "phpunit/phpunit": "^10",
    "yoast/phpunit-polyfills": "^2"
  },
  "scripts": {
    "lint": "phpcs --standard=phpcs.xml.dist --warning-severity=0",
    "lint-fix": "phpcbf --standard=phpcs.xml.dist",
    "test": "phpunit",
    "test:contracts": "phpunit tests/php/BootPayloadContractTest.php tests/php/RestRouteContractTest.php tests/php/RestRoutePermissionCompatibilityTest.php tests/php/PluginEntryCompatibilityTest.php tests/php/ArtifactContractTest.php"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
